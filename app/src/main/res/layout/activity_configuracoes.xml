<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Toolbar configurada para bater com o ID do seu código Kotlin -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_config"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0A1E3A"
        app:title="Configurações"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back_arrow_black" />

    <!-- RecyclerView para listar as opções (Tema, Compartilhar, Sobre) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_configuracoes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp" />

</LinearLayout>