package com.horizontenews.app

import android.content.Intent
import android.os.Bundle
import android.widget.ImageButton
import androidx.appcompat.app.AppCompatActivity
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView

class ConfiguracoesActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_configuracoes)

        val toolbar = findViewById<androidx.appcompat.widget.Toolbar>(R.id.toolbar_config)
        setSupportActionBar(toolbar)
        supportActionBar?.setDisplayHomeAsUpEnabled(true)

        toolbar.setNavigationOnClickListener { finish() }

        val recyclerView = findViewById<RecyclerView>(R.id.recycler_configuracoes)
        recyclerView.layoutManager = LinearLayoutManager(this)

        // Lista de configurações (sem "Meus Salvos")
        val items = listOf(
            ConfigItem("Tema", R.drawable.ic_settings_gear),
            ConfigItem("Compartilhar App", R.drawable.ic_share_black_custom),
            ConfigItem("Sobre o App", R.drawable.ic_info)
        )

        recyclerView.adapter = ConfiguracoesAdapter(items) { item ->
            when (item.title) {
                "Tema" -> {
                    // TODO: Trocar tema
                }
                "Compartilhar App" -> {
                    val shareIntent = Intent(Intent.ACTION_SEND).apply {
                        type = "text/plain"
                        putExtra(Intent.EXTRA_TEXT, "Baixe o Horizonte News!")
                    }
                    startActivity(Intent.createChooser(shareIntent, "Compartilhar"))
                }
                "Sobre o App" -> {
                    // TODO: Abrir tela sobre
                }
            }
        }
    }
}

// Classe auxiliar
data class ConfigItem(val title: String, val iconRes: Int)